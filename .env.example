# Optional Hugging Face token if the model requires it
# HF_TOKEN=hf_...

# --- vLLM container (profile: with-vllm) ---
VLLM_PORT=8000
VLLM_MODEL=Qwen/Qwen3.6-35B-A3B
VLLM_TENSOR_PARALLEL_SIZE=1
MAX_MODEL_LEN=32768
GPU_MEMORY_UTILIZATION=0.90
NUM_SPECULATIVE_TOKENS=5

# --- Chat UI (web service) ---
WEB_PORT=3000
# OpenAI-compatible base URL seen from the web container.
# Host vLLM (default): http://host.docker.internal:8000/v1
# Same compose stack: http://vllm:8000/v1
VLLM_BASE_URL=http://host.docker.internal:8000/v1
VLLM_API_KEY=sk-local-edge
